SELECT
    pha.po_header_id,
    pov.co_sequence,
    pea.email_address AS approver,
    
    pah.performer_id AS approver_id,
    pah.action_date AS approval_date

FROM po_action_history pah
JOIN po_headers_all pha
    ON pha.po_header_id = pah.object_id
JOIN po_versions pov
    ON pov.po_header_id = pha.po_header_id
    AND pov.po_header_id = pah.object_id

LEFT JOIN por_approval_task_comments patc
    ON patc.object_id = pah.object_id
    AND patc.performer_id = pah.performer_id
    AND patc.identification_key = pah.identification_key

WHERE pah.action_code = 'APPROVE'
    AND pah.performer_id IS NOT NULL
    AND pov.co_sequence > 0

