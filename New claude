WITH xxtgf_po_approval AS
(SELECT DISTINCT
    FndBpmTaskHistoryEO.IDENTIFICATION_KEY AS identificationkey,
    FndBpmTaskPEO.OUTCOME_CODE as OUTCOME ,
    NULL state,
    NULL UPDATEDBYDISPLAYNAME,
    NVL((select DISTINCT ppnf.display_name
    from per_all_people_f    papf
       , per_person_names_f  ppnf
       , per_email_addresses pea
    WHERE  SYSDATE BETWEEN NVL(papf.effective_start_date, SYSDATE) AND NVL(papf.effective_end_date, SYSDATE)
    AND    pea.email_address_id(+) = papf.primary_email_id
    AND    SYSDATE BETWEEN NVL(pea.date_from(+), SYSDATE) AND NVL(pea.date_to(+), SYSDATE)
    and    ppnf.person_id(+) = papf.person_id
    and    ppnf.name_type(+) = 'GLOBAL'
    and    SYSDATE BETWEEN NVL(ppnf.effective_start_date(+), SYSDATE) AND NVL(ppnf.effective_end_date(+), SYSDATE)
    and    sysdate between nvl(papf.effective_start_date, sysdate) and nvl(papf.effective_end_date, sysdate)
 and   UPPER(TRIM(pea.EMAIL_ADDRESS)) = UPPER(TRIM(FndBpmTaskAssigneePEO.ASSIGNEE))),FndBpmTaskAssigneePEO.ASSIGNEE) AS ASSIGNEE ,
    poh.DOCUMENT_STATUS,
    poh.segment1,
    poh.po_header_id,
 pov.CO_NUM,
 pov.revision_num,
 pbpn.auction_header_id,
    TO_CHAR(FndBpmTaskPEO.COMPLETED_DATE,'DD-MON-YYYY HH24:MI:SS','NLS_DATE_LANGUAGE = AMERICAN') action_date
  FROM FUSION.FND_BPM_TASK_VL FndBpmTaskPEO,
    FUSION.FND_BPM_TASK_HISTORY_B FndBpmTaskHistoryEO,
    FUSION.FND_BPM_TASK_ASSIGNEE FndBpmTaskAssigneePEO,
    FUSION.po_versions pov,
 FUSION.po_headers_all poh,
