    NVL(po_change_order.co_sequence, 0) = 0
    AND :P_SELECTED_APPROVER IN (
      poapp.l1_aid,  poapp.l2_aid,  poapp.l3_aid,
      poapp.l4_aid,  poapp.l5_aid,  poapp.l6_aid,
